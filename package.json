{
  "name": "portfolio-navigator-code-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "deploy": "npm run build && npx power-apps push && node scripts/play-url.mjs",
